    private const int ModuleHeight = 1000;
    private const int AssembledWidth = 1920;
    private const int AssembledHeight = 1080;
    private const int ContactWidth = 2400;
    private const int ContactHeight = 1700;

    private const string TextureFolderRelativePath = "Assets/_Project/ArtStaging/FinalMaterialsV1/Textures";
    private const string ReportRelativePath = "Documentation/AssetProduction/EnvironmentLookdev/ENV_RECOVERY03_UNITY_ENVIRONMENT_LOOKDEV_REPORT.md";
    private const string MetricsRelativePath = "Documentation/AssetProduction/EnvironmentLookdev/env_recovery03_unity_environment_lookdev_metrics.json";
    private const string ContactRelativePath = "Documentation/ConceptRenders/CONTACTSHEET_ENV_Recovery03_unity_environment_lookdev_proof.jpg";
    private const string WallBayRelativePath = "Documentation/ConceptRenders/RENDER_ENV_Recovery03_modular_wall_bay_unity_proof.jpg";
    private const string PipeCanopyRelativePath = "Documentation/ConceptRenders/RENDER_ENV_Recovery03_pipe_canopy_gauge_cluster_unity_proof.jpg";
    private const string PressureDoorRelativePath = "Documentation/ConceptRenders/RENDER_ENV_Recovery03_pressure_door_module_unity_proof.jpg";
    private const string AssembledSliceRelativePath = "Documentation/ConceptRenders/RENDER_ENV_Recovery03_assembled_corridor_slice_unity_proof.jpg";
    private const string LogRelativePath = "Logs/env-recovery03-unity-environment-lookdev.log";
    private const string ExactUnityCommandUsed = "\"C:\\Program Files\\Unity\\Hub\\Editor\\6000.4.6f1\\Editor\\Unity.exe\" -batchmode -quit -projectPath \"D:\\__MY APPS\\Unity Doom\" -executeMethod UnityEnvironmentRecovery03ProofRenderer.RenderBatch -logFile \"D:\\__MY APPS\\Unity Doom\\Logs\\env-recovery03-unity-environment-lookdev.log\"";

    [MenuItem("Project Tools/Lookdev/Render Recovery03 Unity Environment Proof")]
    public static void RenderFromMenu()
    {
        RenderBatch();
    }

    public static void RenderBatch()
    {
        try
        {
            RenderProof();
        }
        catch (Exception exception)
        {
            Debug.LogException(exception);
            if (Application.isBatchMode)
            {
                EditorApplication.Exit(1);
            }

            throw;
        }
    }

    private static void RenderProof()
    {
        string projectRoot = GetProjectRoot();
        Directory.CreateDirectory(Path.Combine(projectRoot, "Documentation/ConceptRenders"));
        Directory.CreateDirectory(Path.Combine(projectRoot, "Documentation/AssetProduction/EnvironmentLookdev"));
        Directory.CreateDirectory(Path.Combine(projectRoot, "Logs"));

        EnvironmentLookdevMetrics metrics = new EnvironmentLookdevMetrics
        {
            timestamp = DateTimeOffset.Now.ToString("yyyy-MM-dd HH:mm:ss zzz", CultureInfo.InvariantCulture),
            unityVersion = Application.unityVersion,
            batchmodeEntrypoint = "UnityEnvironmentRecovery03ProofRenderer.RenderBatch",
            exactUnityCommandUsed = ExactUnityCommandUsed,
            logPath = LogRelativePath,
            textureSourceFolder = TextureFolderRelativePath,
            reportPath = ReportRelativePath,
            metricsPath = MetricsRelativePath,
            contactSheetPath = ContactRelativePath,
            moduleRenderWidth = ModuleWidth,
            moduleRenderHeight = ModuleHeight,
            assembledRenderWidth = AssembledWidth,
            assembledRenderHeight = AssembledHeight,
            contactSheetWidth = ContactWidth,
            contactSheetHeight = ContactHeight,
            materialSourcesUsed = new string[]
            {
                "T_BBW_WetOilDarkStone_*_2048.png",
                "T_BBW_SootBrick_*_2048.png",
                "T_BBW_BlackenedRivetedIron_*_2048.png",
                "T_BBW_AgedBrass_*_2048.png",
                "T_BBW_CopperPipe_*_2048.png",
                "T_BBW_AmberGlass_*_2048.png",
                "T_BBW_CreamEnamelGauge_*_2048.png",
                "T_BBW_HazardEnamel_*_2048.png",
                "T_BBW_LeatherBellows_*_2048.png",
                "T_BBW_ScorchOilDecalAtlas_*_2048.png"
            }
        };

        Recovery03Materials materials = null;
        Texture2D contactSheet = null;
        List<RenderResult> results = new List<RenderResult>();

        try
        {
            OwnedTextures.Clear();
            EditorSceneManager.NewScene(NewSceneSetup.EmptyScene, NewSceneMode.Single);
            materials = CreateMaterials(projectRoot, metrics);

            results.Add(RenderSingle(projectRoot, metrics, "modular_wall_bay", "Modular wall bay", WallBayRelativePath, ModuleWidth, ModuleHeight, materials, BuildWallBayScene, new Vector3(3.45f, 1.78f, -4.25f), new Vector3(0.0f, 1.35f, 1.55f), 40.0f));
            results.Add(RenderSingle(projectRoot, metrics, "pipe_canopy_gauge_cluster", "Pipe canopy and gauge cluster", PipeCanopyRelativePath, ModuleWidth, ModuleHeight, materials, BuildPipeCanopyScene, new Vector3(2.75f, 2.8f, -3.55f), new Vector3(0.0f, 1.95f, 1.25f), 38.0f));
            results.Add(RenderSingle(projectRoot, metrics, "pressure_door_module", "Pressure vault door module", PressureDoorRelativePath, ModuleWidth, ModuleHeight, materials, BuildPressureDoorScene, new Vector3(0.0f, 1.55f, -5.45f), new Vector3(0.0f, 1.45f, 1.25f), 34.0f));
            results.Add(RenderSingle(projectRoot, metrics, "assembled_corridor_slice", "Assembled corridor slice", AssembledSliceRelativePath, AssembledWidth, AssembledHeight, materials, BuildAssembledCorridorScene, new Vector3(0.25f, 1.42f, -5.9f), new Vector3(0.0f, 1.45f, 3.3f), 43.0f));

            metrics.renderedImageCount = results.Count;
            metrics.imageMetrics = BuildImageMetrics(projectRoot, results);
            metrics.gates = BuildGates(metrics);
            metrics.overallStatus = DetermineOverallStatus(metrics.gates);

            contactSheet = BuildContactSheet(projectRoot, results);
            string contactPath = Path.Combine(projectRoot, ContactRelativePath);
            File.WriteAllBytes(contactPath, contactSheet.EncodeToJPG(94));
            metrics.contactSheetImageMetric = AnalyzeImage("contact_sheet", ContactRelativePath, contactSheet);
            metrics.gates = BuildGates(metrics);
            metrics.overallStatus = DetermineOverallStatus(metrics.gates);

            File.WriteAllText(Path.Combine(projectRoot, MetricsRelativePath), JsonUtility.ToJson(metrics, true));
            File.WriteAllText(Path.Combine(projectRoot, ReportRelativePath), BuildReport(metrics));

            Debug.Log("ENV Recovery03 Unity environment lookdev contact sheet written to " + contactPath);
            Debug.Log("ENV Recovery03 Unity environment lookdev report written to " + Path.Combine(projectRoot, ReportRelativePath));
        }
        finally
        {
            DestroyTexture(contactSheet);
            for (int i = 0; i < results.Count; i++)
            {
                DestroyTexture(results[i].Image);
            }

            if (materials != null)
            {
                materials.DestroyAll();
            }

            DestroyOwnedTextures();
            EditorSceneManager.NewScene(NewSceneSetup.EmptyScene, NewSceneMode.Single);
        }
    }

    private static RenderResult RenderSingle(string projectRoot, EnvironmentLookdevMetrics metrics, string key, string title, string relativePath, int width, int height, Recovery03Materials materials, SceneBuilder builder, Vector3 cameraPosition, Vector3 lookAt, float fov)
    {
        EditorSceneManager.NewScene(NewSceneSetup.EmptyScene, NewSceneMode.Single);
        ConfigureRenderSettings();

        GameObject root = new GameObject("ENV_Recovery03_" + key);
        builder(root.transform, materials, metrics);
        BuildSharedLighting(metrics);

        Camera camera = CreateCamera("ENV_Recovery03_Camera_" + key, cameraPosition, lookAt, fov, width, height);
        Texture2D image = CaptureCamera(camera, width, height, new Color(0.018f, 0.015f, 0.012f, 1f));
        File.WriteAllBytes(Path.Combine(projectRoot, relativePath), image.EncodeToJPG(95));
        DestroyTexture(image);

        return new RenderResult
        {
            Key = key,
            Title = title,
            RelativePath = relativePath,
            Width = width,
            Height = height,
            Image = null
        };
    }

    private static void ConfigureRenderSettings()
    {
        RenderSettings.ambientMode = AmbientMode.Flat;
        RenderSettings.ambientLight = new Color(0.038f, 0.032f, 0.026f);
        RenderSettings.fog = true;
        RenderSettings.fogColor = new Color(0.033f, 0.029f, 0.025f);
        RenderSettings.fogMode = FogMode.ExponentialSquared;
        RenderSettings.fogDensity = 0.029f;
        RenderSettings.reflectionIntensity = 0.48f;
    }

    private static Recovery03Materials CreateMaterials(string projectRoot, EnvironmentLookdevMetrics metrics)
    {
        Recovery03Materials materials = new Recovery03Materials();
        materials.WetStone = CreatePbrMaterial(projectRoot, "WetOilDarkStone", "ENV_R03_WetOilDarkStone", 0.05f, 0.82f, new Vector2(2.0f, 4.2f), metrics, false, false, Color.white);
        materials.SootBrick = CreatePbrMaterial(projectRoot, "SootBrick", "ENV_R03_SootBrick", 0.0f, 0.34f, new Vector2(2.3f, 2.5f), metrics, false, false, new Color(0.72f, 0.69f, 0.63f));
        materials.BlackenedIron = CreatePbrMaterial(projectRoot, "BlackenedRivetedIron", "ENV_R03_BlackenedRivetedIron", 0.88f, 0.42f, new Vector2(1.4f, 1.4f), metrics, false, false, Color.white);
        materials.AgedBrass = CreatePbrMaterial(projectRoot, "AgedBrass", "ENV_R03_AgedBrass", 0.94f, 0.58f, new Vector2(1.2f, 1.2f), metrics, false, false, Color.white);
        materials.CopperPipe = CreatePbrMaterial(projectRoot, "CopperPipe", "ENV_R03_CopperPipe", 0.95f, 0.64f, new Vector2(1.7f, 1.0f), metrics, false, false, Color.white);
        materials.AmberGlass = CreatePbrMaterial(projectRoot, "AmberGlass", "ENV_R03_AmberGlass", 0.0f, 0.78f, Vector2.one, metrics, true, true, new Color(1.0f, 0.72f, 0.32f, 0.58f));
        materials.CreamGauge = CreatePbrMaterial(projectRoot, "CreamEnamelGauge", "ENV_R03_CreamGauge", 0.0f, 0.5f, Vector2.one, metrics, false, false, Color.white);
        materials.HazardEnamel = CreatePbrMaterial(projectRoot, "HazardEnamel", "ENV_R03_HazardEnamel", 0.0f, 0.52f, Vector2.one, metrics, false, false, Color.white);
        materials.LeatherBellows = CreatePbrMaterial(projectRoot, "LeatherBellows", "ENV_R03_LeatherBellows", 0.0f, 0.37f, Vector2.one, metrics, false, false, Color.white);
        materials.Decal = CreateDecalMaterial(projectRoot, metrics);
        materials.WetHighlight = CreateTransparentColorMaterial("ENV_R03_WetHighlight", new Color(1.0f, 0.62f, 0.22f, 0.24f), 0.0f, 0.95f);
        materials.Steam = CreateTransparentColorMaterial("ENV_R03_SteamFog", new Color(0.78f, 0.72f, 0.62f, 0.24f), 0.0f, 0.3f);
        materials.WarmGlow = CreateUnlitColorMaterial("ENV_R03_WarmLampGlow", new Color(1.0f, 0.52f, 0.15f, 1f), true);
        materials.LineDark = CreateUnlitColorMaterial("ENV_R03_LineDark", new Color(0.035f, 0.027f, 0.019f, 1f), false);
        materials.RedGlow = CreateUnlitColorMaterial("ENV_R03_RedGlow", new Color(1.0f, 0.1f, 0.035f, 1f), true);
        materials.GreenGlow = CreateUnlitColorMaterial("ENV_R03_GreenGlow", new Color(0.22f, 0.95f, 0.42f, 1f), true);
        materials.ContactBack = CreateUnlitColorMaterial("ENV_R03_ContactBack", new Color(0.025f, 0.021f, 0.018f, 1f), false);
        metrics.materialFamiliesUsed = 13;
        return materials;
    }

    private static Material CreatePbrMaterial(string projectRoot, string materialKey, string materialName, float defaultMetallic, float defaultSmoothness, Vector2 tiling, EnvironmentLookdevMetrics metrics, bool transparent, bool emission, Color tint)
    {
        Shader shader = Shader.Find("Universal Render Pipeline/Lit");
        if (shader == null)
        {
            shader = Shader.Find("Standard");
        }

        Material material = new Material(shader);
        material.name = materialName;

        Texture2D baseMap = LoadTextureFromDisk(projectRoot, materialKey, "BaseColor", false, metrics);
        Texture2D normalMap = LoadTextureFromDisk(projectRoot, materialKey, "Normal", true, metrics);
        Texture2D ormMap = LoadTextureFromDisk(projectRoot, materialKey, "ORM", true, metrics);
        Texture2D metallicSmoothness = null;
        Texture2D occlusion = null;
        if (ormMap != null)
        {
            metallicSmoothness = CreateMetallicSmoothnessFromOrm(ormMap, materialName + "_MetallicSmoothness");
            occlusion = CreateOcclusionFromOrm(ormMap, materialName + "_Occlusion");
        }

        SetMaterialTexture(material, "_MainTex", baseMap);
        SetMaterialTexture(material, "_BaseMap", baseMap);
        SetMaterialTexture(material, "_BumpMap", normalMap);
        SetMaterialTexture(material, "_NormalMap", normalMap);
        SetMaterialTexture(material, "_OcclusionMap", occlusion);
        SetMaterialTexture(material, "_MetallicGlossMap", metallicSmoothness);
        SetMaterialFloat(material, "_Metallic", defaultMetallic);
        SetMaterialFloat(material, "_Glossiness", defaultSmoothness);
        SetMaterialFloat(material, "_Smoothness", defaultSmoothness);
        SetMaterialColor(material, tint);

        if (baseMap != null)
        {
            material.mainTexture = baseMap;
        }

        SetMaterialTextureScale(material, "_MainTex", tiling);
        SetMaterialTextureScale(material, "_BaseMap", tiling);
        material.EnableKeyword("_NORMALMAP");
        material.EnableKeyword("_OCCLUSIONMAP");
        material.EnableKeyword("_METALLICGLOSSMAP");

        if (transparent)
        {
            material.SetOverrideTag("RenderType", "Transparent");
            material.renderQueue = (int)RenderQueue.Transparent;
            SetMaterialFloat(material, "_Surface", 1.0f);
            SetMaterialFloat(material, "_Mode", 3.0f);
            SetMaterialInt(material, "_SrcBlend", (int)BlendMode.SrcAlpha);
            SetMaterialInt(material, "_DstBlend", (int)BlendMode.OneMinusSrcAlpha);
            SetMaterialInt(material, "_ZWrite", 0);
            material.EnableKeyword("_ALPHABLEND_ON");
        }

        if (emission)
        {
            SetMaterialColor(material, "_EmissionColor", new Color(1.0f, 0.44f, 0.11f) * 1.6f);
            material.EnableKeyword("_EMISSION");
        }

        TrackOwnedTexture(baseMap);
        TrackOwnedTexture(normalMap);
        TrackOwnedTexture(ormMap);
        TrackOwnedTexture(metallicSmoothness);
        TrackOwnedTexture(occlusion);
        return material;
    }

    private static Material CreateDecalMaterial(string projectRoot, EnvironmentLookdevMetrics metrics)
    {
        Material material = CreatePbrMaterial(projectRoot, "ScorchOilDecalAtlas", "ENV_R03_ScorchOilDecal", 0.0f, 0.62f, Vector2.one, metrics, true, false, new Color(1f, 1f, 1f, 0.46f));
        Texture2D alpha = LoadTextureFromDisk(projectRoot, "ScorchOilDecalAtlas", "Alpha", true, metrics);
        SetMaterialTexture(material, "_BaseMap", material.mainTexture);
        SetMaterialTexture(material, "_MainTex", material.mainTexture);
        if (alpha != null)
        {
            SetMaterialTexture(material, "_AlphaTex", alpha);
        }

        TrackOwnedTexture(alpha);
        return material;
    }

    private static Material CreateTransparentColorMaterial(string materialName, Color color, float metallic, float smoothness)
    {
        Shader shader = Shader.Find("Universal Render Pipeline/Lit");
        if (shader == null)
        {
            shader = Shader.Find("Standard");
        }

        Material material = new Material(shader);
        material.name = materialName;
        SetMaterialColor(material, color);
        SetMaterialColor(material, "_BaseColor", color);
        SetMaterialFloat(material, "_Metallic", metallic);
        SetMaterialFloat(material, "_Smoothness", smoothness);
        SetMaterialFloat(material, "_Glossiness", smoothness);
        SetMaterialFloat(material, "_Surface", 1f);
        SetMaterialFloat(material, "_Mode", 3f);
        SetMaterialInt(material, "_SrcBlend", (int)BlendMode.SrcAlpha);
        SetMaterialInt(material, "_DstBlend", (int)BlendMode.OneMinusSrcAlpha);
        SetMaterialInt(material, "_ZWrite", 0);
        material.SetOverrideTag("RenderType", "Transparent");
        material.renderQueue = (int)RenderQueue.Transparent + 12;
        material.EnableKeyword("_ALPHABLEND_ON");
        return material;
    }

    private static Material CreateUnlitColorMaterial(string materialName, Color color, bool emission)
    {
        Shader shader = Shader.Find("Universal Render Pipeline/Unlit");
        if (shader == null)
        {
            shader = Shader.Find("Universal Render Pipeline/Lit");
        }

        if (shader == null)
        {
            shader = Shader.Find("Standard");
        }

        Material material = new Material(shader);
        material.name = materialName;
        SetMaterialColor(material, color);
        SetMaterialColor(material, "_BaseColor", color);
        if (emission)
        {
            SetMaterialColor(material, "_EmissionColor", color * 1.8f);
            material.EnableKeyword("_EMISSION");
        }

        return material;
    }

    private static Texture2D LoadTextureFromDisk(string projectRoot, string materialKey, string textureRole, bool linear, EnvironmentLookdevMetrics metrics)
    {
        string relativePath = TextureFolderRelativePath + "/T_BBW_" + materialKey + "_" + textureRole + "_2048.png";
        string absolutePath = Path.Combine(projectRoot, relativePath.Replace("/", Path.DirectorySeparatorChar.ToString()));
        metrics.textureFilesExpected++;
        if (!File.Exists(absolutePath))
        {
            metrics.textureFilesMissing++;
            metrics.missingTextureNotes.Add(relativePath);
            return null;
        }

        Texture2D texture = new Texture2D(2, 2, TextureFormat.RGBA32, false, linear);
        if (!texture.LoadImage(File.ReadAllBytes(absolutePath)))
        {
            metrics.textureFilesMissing++;
            metrics.missingTextureNotes.Add(relativePath + " failed LoadImage");
            UnityEngine.Object.DestroyImmediate(texture);
            return null;
        }

        texture.name = "ENV_R03_Loaded_" + materialKey + "_" + textureRole;
        texture.wrapMode = TextureWrapMode.Repeat;
        texture.filterMode = FilterMode.Trilinear;
        texture.anisoLevel = 4;
        metrics.textureFilesLoaded++;
        return texture;
    }

    private static Texture2D CreateMetallicSmoothnessFromOrm(Texture2D orm, string name)
    {
        Texture2D output = new Texture2D(orm.width, orm.height, TextureFormat.RGBA32, false, true);
        Color[] pixels = orm.GetPixels();
        for (int i = 0; i < pixels.Length; i++)
        {
            Color pixel = pixels[i];
            float roughness = pixel.g;
            output.SetPixel(i % orm.width, i / orm.width, new Color(pixel.b, pixel.b, pixel.b, 1.0f - roughness));
        }

        output.name = name;
        output.wrapMode = TextureWrapMode.Repeat;
        output.filterMode = FilterMode.Trilinear;
        output.Apply(false, false);
        TrackOwnedTexture(output);
        return output;
    }

    private static Texture2D CreateOcclusionFromOrm(Texture2D orm, string name)
    {
        Texture2D output = new Texture2D(orm.width, orm.height, TextureFormat.RGBA32, false, true);
        Color[] pixels = orm.GetPixels();
        for (int i = 0; i < pixels.Length; i++)
        {
            float ao = pixels[i].r;
            output.SetPixel(i % orm.width, i / orm.width, new Color(ao, ao, ao, 1f));
        }

        output.name = name;
        output.wrapMode = TextureWrapMode.Repeat;
        output.filterMode = FilterMode.Trilinear;
        output.Apply(false, false);
        TrackOwnedTexture(output);
        return output;
    }

    private static void BuildWallBayScene(Transform root, Recovery03Materials materials, EnvironmentLookdevMetrics metrics)
    {
        BuildCorridorShell(root, materials, metrics, 4.8f, 5.2f, false);
        BuildWallBay(root, materials, metrics, -2.45f, 2.2f, true);
        BuildWallBay(root, materials, metrics, 2.45f, 2.2f, false);
        BuildRail(root, materials, metrics, -2.08f, 0.88f, -1.8f, 4.8f, true);
        BuildGasLamp(root, materials, metrics, new Vector3(-2.19f, 1.95f, 1.05f), Vector3.right, 1.35f);
        BuildGauge(root, materials, metrics, new Vector3(-2.2f, 1.44f, 2.25f), Vector3.right, 0.26f);
        BuildValveWheel(root, materials, metrics, new Vector3(-2.18f, 1.13f, 2.85f), Vector3.right, 0.26f);
        BuildSteamCluster(root, materials, metrics, new Vector3(-2.05f, 1.78f, 3.7f), 0.7f, 6);
        AddOilDecal(root, materials, metrics, new Vector3(-0.75f, 0.075f, 2.4f), new Vector3(1.0f, 0.01f, 0.44f), 12f);
    }

